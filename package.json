{
  "name": "coincart-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5"
  },
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/run-with-root-env.ps1 pnpm --parallel --filter @coincart/api --filter @coincart/web dev",
    "dev:api": "powershell -ExecutionPolicy Bypass -File scripts/run-with-root-env.ps1 pnpm --filter @coincart/api dev",
    "dev:web": "powershell -ExecutionPolicy Bypass -File scripts/run-with-root-env.ps1 pnpm --filter @coincart/web dev",
    "build": "%APPDATA%\\npm\\pnpm.cmd -r build",
    "typecheck": "%APPDATA%\\npm\\pnpm.cmd -r typecheck"
  }
}
