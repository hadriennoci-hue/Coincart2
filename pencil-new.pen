            },
            {
              "type": "text",
              "id": "dKxTu",
              "name": "tosHeroSub",
              "fill": "#9CA3AF",
              "content": "General Conditions — Please read carefully before ordering",
              "fontFamily": "Inter",
              "fontSize": 15,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "u1bqA",
          "name": "tos-body",
          "width": 1440,
          "fill": "#0F172A",
          "layout": "vertical",
          "gap": 16,
          "children": [
            {
              "type": "frame",
              "id": "XaOqn",
              "name": "tos1",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 10,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "C0k1p",
                  "name": "tos1h",
                  "fill": "#FFFFFF",
                  "content": "1. Introduction",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "P7ApP",
                  "name": "tos1p1",
                  "fill": "#9CA3AF",
                  "content": "1.1 Parties and definitions:",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "DPMQs",
                  "name": "tos1li1",
                  "fill": "#9CA3AF",
                  "content": "• \"Client\" is any person wishing to make a transaction on Coincart.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "IN5NL",
                  "name": "tos1li2",
                  "fill": "#9CA3AF",
                  "content": "• \"Supplier\" means one of Coincart suppliers (as of February 19th 2025, ACER Predator).",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "dl1cS",
                  "name": "tos1li3",
                  "fill": "#9CA3AF",
                  "content": "• \"Merchant\" is Coincart, the platform processing the sales.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "7iBa1",
                  "name": "tos1li4",
                  "fill": "#9CA3AF",
                  "content": "• \"Transporter\" is the company that ships the Orders (DHL in Europe).",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "SDVhY",
                  "name": "tos1p2",
                  "fill": "#9CA3AF",
                  "content": "1.2 Purpose: This agreement defines the terms and responsibilities of each party during the order of a Product on Coincart by the Client.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "543N7",
              "name": "tos2",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 10,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "S2s09",
                  "name": "tos2h",
                  "fill": "#FFFFFF",
                  "content": "2. Purpose",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "MgvdS",
                  "name": "tos2t",
                  "fill": "#9CA3AF",
                  "content": "2.2 Coincart administrates the usage of the platform, listing Suppliers products and processing sales for Clients. Coincart transfers the orders to the Supplier, communicates the shipping URL and information to the Client, and answers any question regarding order, refund or warranty. If there is a problem with the order, Coincart pledges to do everything possible to help the Client resolve the situation.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "1J2PF",
              "name": "tos3",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 10,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "2Xtha",
                  "name": "tos3h",
                  "fill": "#FFFFFF",
                  "content": "3. Products",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "sSjJT",
                  "name": "tos3t1",
                  "fill": "#9CA3AF",
                  "content": "3.1 As of February 20th 2025, Coincart sells all the ACER / Predator catalog and may add more brands.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "jUkHS",
                  "name": "tos3t2",
                  "fill": "#9CA3AF",
                  "content": "3.2 Availability: Updated daily. If a product is unavailable, Coincart offers (a) waiting for restock, or (b) immediate 100% refund including shipping and gas fees.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "tcrPl",
                  "name": "tos3t3",
                  "fill": "#9CA3AF",
                  "content": "3.3 Pricing: Prices are subject to change and do not include shipping fees shown separately at checkout.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "7rmLd",
              "name": "tos4",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 10,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "ZwQ24",
                  "name": "tos4h",
                  "fill": "#FFFFFF",
                  "content": "4. Payment Terms",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "H5EEr",
                  "name": "tos4t1",
                  "fill": "#9CA3AF",
                  "content": "4.1 Payment processor: Coincart uses BTCPay Server.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "easUU",
                  "name": "tos4t2",
                  "fill": "#9CA3AF",
                  "content": "4.2 Cryptos accepted: BTC, USDT (TRON), XMR.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "EZgN0",
                  "name": "tos4t3",
                  "fill": "#9CA3AF",
                  "content": "4.3 Coincart waits for blockchain confirmation before considering payment confirmed and starting order processing.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "fLP0O",
              "name": "tos5",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 10,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "kJWfr",
                  "name": "tos5h",
                  "fill": "#FFFFFF",
                  "content": "5. Order Acceptance and Cancellation",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "yhMGy",
                  "name": "tos5t1",
                  "fill": "#9CA3AF",
                  "content": "5.1 Coincart reserves the right to cancel orders (insufficient shipping data, missing/invalid contact info, unavailable supplier stock, or other reasons). Coincart notifies by email and refunds 100%.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "VmgmH",
                  "name": "tos5t2",
                  "fill": "#9CA3AF",
                  "content": "5.2 The Client can cancel within 14 days after receiving the product, subject to section 8 conditions.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "4anFu",
              "name": "tos6",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 10,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "3CW8H",
                  "name": "tos6h",
                  "fill": "#FFFFFF",
                  "content": "6. Shipping and Delivery",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "OVLJs",
                  "name": "tos6t1",
                  "fill": "#9CA3AF",
                  "content": "6.1 The Supplier processes orders via DHL, and so does Coincart.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "RnY4i",
                  "name": "tos6t2",
                  "fill": "#9CA3AF",
                  "content": "6.2 After payment confirmation, supplier shipping usually starts in about 2 days.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "MNdFM",
                  "name": "tos6t3",
                  "fill": "#9CA3AF",
                  "content": "6.3 The Client is responsible for receiving the shipment. 6.4 Delivery times vary by destination (e.g. 2–4 days in France).",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "lGY6G",
              "name": "tos7",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 10,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "AAsO5",
                  "name": "tos7h",
                  "fill": "#FFFFFF",
                  "content": "7. Customer Responsibilities",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "35XPB",
                  "name": "tos7t",
                  "fill": "#9CA3AF",
                  "content": "By placing an order, the Client confirms legal age (18+), legal entitlement to use the chosen payment method, and agrees to these terms. A valid order requires a valid address, delivery phone number, and email. Client is responsible for complying with local laws regarding cryptocurrency transactions.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "PDhkC",
              "name": "tos8",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 10,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "TDdHs",
                  "name": "tos8h",
                  "fill": "#FFFFFF",
                  "content": "8. 14-Day Free Return",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "ZQNQj",
                  "name": "tos8t",
                  "fill": "#9CA3AF",
                  "content": "The Client has a fourteen-day withdrawal period from shipment completion. To withdraw, Client must send an unambiguous request with identification details before the deadline. After supplier receipt and inspection, Coincart refunds (excluding delivery costs) using the original payment method.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "tIwPx",
              "name": "tos9",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 10,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "y3BLE",
                  "name": "tos9h",
                  "fill": "#FFFFFF",
                  "content": "9–13. Warranty, Liability & Contact",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "pw8MF",
                  "name": "tos9t1",
                  "fill": "#9CA3AF",
                  "content": "9. Coincart applies supplier/manufacturer warranties where available. For warranty activation, contact support by email.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "UfNst",
                  "name": "tos9t2",
                  "fill": "#9CA3AF",
                  "content": "10. Coincart shall not be liable for delivery errors on supplier/transporter side, or product issues, but will do everything possible to help resolve issues.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "KXRwf",
                  "name": "tos9t3",
                  "fill": "#9CA3AF",
                  "content": "11. Coincart reserves the right to change these terms.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "civF3",
                  "name": "tos9t4",
                  "fill": "#0F766E",
                  "content": "12. Contact: coincartstore@proton.me",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "8FNCO",
                  "name": "tos9t5",
                  "fill": "#9CA3AF",
                  "content": "13. The Client may create an account (not mandatory) with email and password. Account may include order-related information such as shipping URL and status.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        },
