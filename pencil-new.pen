      "layout": "vertical",
      "children": [
        {
          "id": "WCkzL",
          "type": "ref",
          "ref": "nGOh6",
          "width": 1440,
          "name": "faqNav"
        },
        {
          "type": "frame",
          "id": "wzkuR",
          "name": "hero",
          "width": 1440,
          "height": 160,
          "fill": "#1E293B",
          "layout": "vertical",
          "gap": 8,
          "justifyContent": "center",
          "children": [
            {
              "type": "text",
              "id": "eNP0j",
              "name": "faqHeroTitle",
              "fill": "#FFFFFF",
              "content": "Frequently Asked Questions",
              "fontFamily": "Inter",
              "fontSize": 40,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "T45ja",
              "name": "faqHeroSub",
              "fill": "#9CA3AF",
              "content": "Everything you need to know about ordering with Coincart",
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "irFfI",
          "name": "faq-body",
          "width": 1440,
          "fill": "#0F172A",
          "layout": "vertical",
          "gap": 16,
          "children": [
            {
              "type": "frame",
              "id": "vlsmu",
              "name": "fq1",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 8,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "M8OaS",
                  "name": "fq1q",
                  "fill": "#FFFFFF",
                  "content": "What information is required to complete my order?",
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "krbK3",
                  "name": "fq1a",
                  "fill": "#9CA3AF",
                  "content": "Coincart only needs shipping information: shipping address, contact name, phone and email for tracking.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "yEuUN",
              "name": "fq2",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 8,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "Ewc1G",
                  "name": "fq2q",
                  "fill": "#FFFFFF",
                  "content": "What cryptocurrencies do you accept?",
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "mysNg",
                  "name": "fq2a",
                  "fill": "#9CA3AF",
                  "content": "We accept: USDC, USDT, BTC, XMR, ZEC, SOL, ETH. Our payment processor is BTCPay Server.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "O9Fk1",
              "name": "fq3",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 8,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "QztpI",
                  "name": "fq3q",
                  "fill": "#FFFFFF",
                  "content": "How does the warranty work?",
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "sO7Mt",
                  "name": "fq3a",
                  "fill": "#9CA3AF",
                  "content": "Laptops, Desktops, monitors, GPUs are under two years constructor warranty. If you need to activate warranty, contact Coincart support with Serial Number + proof (photo), then send the product back to ACER. We will connect you with the proper ACER support.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "0djJ5",
              "name": "fq4",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 8,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "rhgZ1",
                  "name": "fq4q",
                  "fill": "#FFFFFF",
                  "content": "Why is shipping more costly for non-local keyboards?",
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "w3YGI",
                  "name": "fq4a",
                  "fill": "#9CA3AF",
                  "content": "For example, a German QWERTZ laptop shipped to France must first go to Germany, then be re-shipped to France per ACER/EU VAT rules. Shipping is therefore more expensive and takes longer. Switzerland and UK can only ship local keyboards as they are not in the EU.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "ggZaW",
              "name": "fq5",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 8,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "R4f3s",
                  "name": "fq5q",
                  "fill": "#FFFFFF",
                  "content": "What countries are currently covered?",
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "09cMk",
                  "name": "fq5a",
                  "fill": "#9CA3AF",
                  "content": "We cover Europe. For large orders over $20K to other continents: send a DM describing your order and shipping destination.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "6HKSh",
              "name": "fq6",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 8,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "XheLx",
                  "name": "fq6q",
                  "fill": "#FFFFFF",
                  "content": "How can I contact Coincart customer support?",
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "ntM0E",
                  "name": "fq6a",
                  "fill": "#9CA3AF",
                  "content": "Our customer service team is available via the contact form or via Telegram. We respond to all inquiries within 24 hours.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "zdGeQ",
              "name": "fq7",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 8,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "5287q",
                  "name": "fq7q",
                  "fill": "#FFFFFF",
                  "content": "What is the return policy?",
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "KmxC8",
                  "name": "fq7a",
                  "fill": "#9CA3AF",
                  "content": "You have 15 days to return the product in its original packaging. Shipping fees are not refunded. Use the contact form with the email used for purchase and product serial number. We will provide ACER Support contact. Upon reception and inspection by ACER STORE, Coincart will initiate refund to the wallet used for payment.",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "Rs1ry",
              "name": "fq8",
              "width": "fill_container",
              "fill": "#1E293B",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 8,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "fVo05",
                  "name": "fq8q",
                  "fill": "#FFFFFF",
                  "content": "Is this partnership with ACER official?",
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
